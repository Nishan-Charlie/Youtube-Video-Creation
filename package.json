{
  "name": "youtube-voiceover-studio",
  "version": "1.0.0",
  "description": "AI-powered YouTube Script & Voiceover Generator",
  "main": "main.js",
  "scripts": {
    "start": "cmd /C \"set ELECTRON_RUN_AS_NODE=&& electron .\"",
    "dev": "cmd /C \"set ELECTRON_RUN_AS_NODE=&& electron . --dev\"",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.youtube.voiceover",
    "productName": "YouTube Voiceover Studio",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist_backend/backend_server.exe",
        "to": "backend_server.exe"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "src/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
